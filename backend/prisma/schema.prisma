datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  password             String
  name                 String
  role                 String         @default("ADMIN") // ADMIN, EMPLOYEE
  businessId           String?
  business             Business?      @relation("BusinessEmployees", fields: [businessId], references: [id], onDelete: SetNull)
  verificationToken    String?
  verificationTokenExp DateTime?
  resetToken           String?
  resetTokenExp        DateTime?
  isVerified           Boolean        @default(false)
  twoFactorSecret      String?
  twoFactorEnabled     Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  businesses           Business[]
  refreshTokens        RefreshToken[]

  @@index([businessId])
}

model Business {
  id                 String               @id @default(uuid())
  ownerId            String
  owner              User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  companyName        String
  website            String
  industry           String
  description        String
  whatsappEnabled    Boolean              @default(false)
  instagramEnabled   Boolean              @default(false)
  emailEnabled       Boolean              @default(false)
  whatsappApiKey     String?
  instagramAccountId String?
  emailSmtp          String?
  themeColor         String               @default("#10B981")
  agentTone          String               @default("PROFESSIONAL")
  agentPrompt        String?
  widgetGreeting     String?              @default("Hello! How can we help you today?")
  widgetRules        String?              @default("[]")
  widgetPosition     String?              @default("bottom-right")
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  leads              Lead[]
  conversations      Conversation[]
  appointments       Appointment[]
  knowledgeBases     KnowledgeBase[]
  visitorTracks      VisitorTrack[]
  competitorAnalyses CompetitorAnalysis[]
  recommendations    Recommendation[]
  employees          User[]               @relation("BusinessEmployees")
}

model KnowledgeBase {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model Lead {
  id              String         @id @default(uuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String?
  email           String?
  phone           String?
  budget          String?
  source          String         @default("WIDGET") // WIDGET, WHATSAPP, INSTAGRAM, EMAIL
  status          String         @default("COLD") // HOT, WARM, COLD
  sentiment       String?
  engagementScore Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  conversations Conversation[]
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, createdAt])
}

model Conversation {
  id              String    @id @default(uuid())
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages        Json      @default("[]") // Native JSON/JSONB of message history: [{role: "user"|"model", content: "..."}]
  channel         String    @default("WIDGET") // WIDGET, WHATSAPP, INSTAGRAM, EMAIL
  isHumanTakeover Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([leadId])
}

model Appointment {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date       String
  time       String
  status     String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([leadId])
}

model VisitorTrack {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location    String   @default("Unknown")
  pagesViewed String   @default("[]") // JSON string array
  duration    Int      @default(0)     // in seconds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, createdAt])
}

model CompetitorAnalysis {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  competitorUrl String
  analysis      String   @default("{}") // JSON string of serviceCompare, missingOfferings, contentGaps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

model Recommendation {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  content    String
  priority   String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  category   String   @default("LEAD")   // LEAD, COMPETITOR, KB
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

