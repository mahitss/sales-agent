datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                   String         @id @default(uuid())
  email                String         @unique
  password             String
  name                 String
  role                 String         @default("ADMIN") // ADMIN, EMPLOYEE
  businessId           String?
  business             Business?      @relation("BusinessEmployees", fields: [businessId], references: [id], onDelete: SetNull)
  verificationToken    String?
  verificationTokenExp DateTime?
  resetToken           String?
  resetTokenExp        DateTime?
  isVerified           Boolean        @default(false)
  twoFactorSecret      String?
  twoFactorEnabled     Boolean        @default(false)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  businesses           Business[]
  refreshTokens        RefreshToken[]
  activityLogs         ActivityLog[]
  organizationId       String?
  organization         Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([organizationId])
}

model Business {
  id                 String               @id @default(uuid())
  ownerId            String
  owner              User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  companyName        String
  website            String
  industry           String
  description        String
  whatsappEnabled    Boolean              @default(false)
  instagramEnabled   Boolean              @default(false)
  emailEnabled       Boolean              @default(false)
  whatsappApiKey     String?
  instagramAccountId String?
  emailSmtp          String?
  themeColor         String               @default("#10B981")
  agentTone          String               @default("PROFESSIONAL")
  agentPrompt        String?
  widgetGreeting     String?              @default("Hello! How can we help you today?")
  widgetRules        String?              @default("[]")
  widgetPosition     String?              @default("bottom-right")
  createdAt          DateTime             @default(now())
  googleSheetsSpreadsheetId String?
  googleSheetsEnabled       Boolean              @default(false)
  leads                     Lead[]
  conversations      Conversation[]
  appointments       Appointment[]
  knowledgeBases     KnowledgeBase[]
  visitorTracks      VisitorTrack[]
  competitorAnalyses CompetitorAnalysis[]
  recommendations    Recommendation[]
  employees          User[]               @relation("BusinessEmployees")
  organizationId     String?
  organization       Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  subscription       Subscription?
  feedbacks          Feedback[]
  aiCostLogs         AICostLog[]
  workflowRules      WorkflowRule[]
  apiKeys            ApiKey[]
  webhookSubscriptions WebhookSubscription[]

  @@index([organizationId])
}

model KnowledgeBase {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model Lead {
  id              String         @id @default(uuid())
  businessId      String
  business        Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String?
  email           String?
  phone           String?
  budget          String?
  source          String         @default("WIDGET") // WIDGET, WHATSAPP, INSTAGRAM, EMAIL
  status          String         @default("COLD") // HOT, WARM, COLD
  sentiment       String?
  engagementScore Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  conversations Conversation[]
  appointments Appointment[]

  // New Relations
  intelligence      LeadIntelligence?
  score             LeadScore?
  enrichment        CompanyEnrichment?
  revenuePrediction RevenuePrediction?
  googleSheetsSync  GoogleSheetsSyncLog?
  outreachSequences OutreachSequence[]

  @@index([businessId])
  @@index([businessId, createdAt])
}

model Conversation {
  id              String    @id @default(uuid())
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages        Json      @default("[]") // Native JSON/JSONB of message history: [{role: "user"|"model", content: "..."}]
  channel         String    @default("WIDGET") // WIDGET, WHATSAPP, INSTAGRAM, EMAIL
  isHumanTakeover Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([leadId])
}

model Appointment {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  date       String
  time       String
  status     String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, createdAt])
  @@index([leadId])
}

model VisitorTrack {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  location    String   @default("Unknown")
  pagesViewed String   @default("[]") // JSON string array
  duration    Int      @default(0)     // in seconds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, createdAt])
}

model CompetitorAnalysis {
  id            String   @id @default(uuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  competitorUrl String
  analysis      String   @default("{}") // JSON string of serviceCompare, missingOfferings, contentGaps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
}

model Recommendation {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title      String
  content    String
  priority   String   @default("MEDIUM") // HIGH, MEDIUM, LOW
  category   String   @default("LEAD")   // LEAD, COMPETITOR, KB
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model LeadIntelligence {
  id                String    @id @default(uuid())
  leadId            String    @unique
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  summary           String
  goals             String
  painPoints        String
  requestedServices String[]  @default([])
  timeline          String
  objections        String
  recommendedAction String
  purchaseReadiness String
  conversionRisk    String
  frequentTopics    String[]  @default([])
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([leadId])
}

model LeadScore {
  id                  String    @id @default(uuid())
  leadId              String    @unique
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  score               Int
  classification      String    // HOT, WARM, COLD
  dealProbability     Float     // Decimal value e.g. 0.84 for 84%
  urgency             String
  decisionMakerStatus String
  businessSize        String
  serviceMatch        String
  engagement          Int
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([leadId])
}

model CompanyEnrichment {
  id                 String    @id @default(uuid())
  leadId             String    @unique
  lead               Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  companyName        String
  website            String?
  industry           String?
  description        String?
  companySize        String?
  country            String?
  socialLinks        Json      @default("{}") // LinkedIn, Twitter, etc.
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([leadId])
}

model RevenuePrediction {
  id             String    @id @default(uuid())
  leadId         String    @unique
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  estimatedValue Float
  probability    Float
  expectedValue  Float     // Calculated: estimatedValue * probability
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([leadId])
}

model GoogleSheetsSyncLog {
  id             String    @id @default(uuid())
  leadId         String    @unique
  lead           Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  spreadsheetId  String
  status         String    @default("PENDING") // PENDING, SUCCESS, FAILED
  attempts       Int       @default(0)
  errorMessage   String?
  syncedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([leadId])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  members     User[]
  businesses  Business[]
}

model UserInvitation {
  id          String   @id @default(uuid())
  email       String
  role        String   @default("EMPLOYEE")
  businessId  String
  token       String   @unique
  status      String   @default("PENDING") // PENDING, ACCEPTED, EXPIRED
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   // e.g. "AUTH_LOGIN", "LEAD_QUALIFY", "SHEET_SYNC", "BILLING_UPDATE"
  description String
  ipAddress   String?
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
}

model Subscription {
  id                   String    @id @default(uuid())
  businessId           String    @unique
  business             Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stripeCustomerId     String?
  stripeSubscriptionId String?   @unique
  status               String    @default("TRIALING") // ACTIVE, CANCELED, PAST_DUE, TRIALING
  planId               String    @default("free") // free, growth, enterprise
  currentPeriodStart   DateTime  @default(now())
  currentPeriodEnd     DateTime  @default(now())
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Feedback {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name        String
  email       String
  category    String   // FEEDBACK, BUG, FEATURE_REQUEST, SUPPORT
  content     String
  status      String   @default("NEW") // NEW, IN_PROGRESS, RESOLVED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AICostLog {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  model       String   // e.g. "gemini-2.5-flash"
  promptTokens Int
  completionTokens Int
  cost        Float    // Calculated cost in USD
  action      String   // e.g. "chat", "lead_analysis", "faq_extract"
  createdAt   DateTime @default(now())
}

model OutreachSequence {
  id           String   @id @default(uuid())
  leadId       String
  lead         Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  template     String   // e.g. "INTRO_PITCH", "FOLLOW_UP"
  subject      String
  body         String
  status       String   @default("SCHEDULED") // SCHEDULED, SENT, FAILED
  scheduledFor DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([leadId])
}

model WorkflowRule {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  trigger    String   // e.g. "STATUS_HOT", "NEW_LEAD"
  action     String   // e.g. "EMAIL_OUTREACH", "SHEET_SYNC"
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model Waitlist {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  status    String   @default("PENDING") // PENDING, APPROVED, CONVERTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Referral {
  id           String   @id @default(uuid())
  code         String   @unique
  referrerId   String
  referrerName String
  refereeEmail String?  @unique
  status       String   @default("PENDING") // PENDING, CONVERTED
  createdAt    DateTime @default(now())
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String
  hashedKey  String    @unique
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role       String    @default("EMPLOYEE")
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?
  lastUsedAt DateTime?

  @@index([businessId])
}

model WebhookSubscription {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  url        String
  secret     String
  events     String[] // e.g. ["lead.created", "lead.qualified"]
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}



