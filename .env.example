# ==========================================
# BEACON AI SALES AGENT ENVIRONMENT TEMPLATE
# ==========================================

# ----------------------------
# Backend (NestJS / Express)
# ----------------------------
# Note: Local development uses BACKEND_PORT. In production, platform sets PORT.
BACKEND_PORT=4000
PORT=4000
DATABASE_URL="file:./dev.db" # SQLite database file location
JWT_SECRET="super-secret-key-change-me-in-production"
JWT_EXPIRATION="1d"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"
JWT_REFRESH_EXPIRATION="7d"
AI_SERVICE_URL="http://localhost:8000"

# ----------------------------
# AI Service (Python FastAPI)
# ----------------------------
GEMINI_API_KEY="your-google-gemini-api-key-here"
# Note: Local development uses AI_PORT. In production, platform sets PORT.
AI_PORT=8000
HOST="0.0.0.0"

# ----------------------------
# Frontend (Next.js)
# ----------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WIDGET_SCRIPT_URL="http://localhost:4000/widget/logicra-widget.js"
