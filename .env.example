# ==========================================
# BEACON AI SALES AGENT ENVIRONMENT TEMPLATE
# ==========================================

# ----------------------------
# Backend (NestJS / Express)
# ----------------------------
# Note: Local development uses BACKEND_PORT. In production, platform sets PORT.
BACKEND_PORT=4000
PORT=4000
DATABASE_URL="postgresql://postgres:password@localhost:5432/beacon_sales_agent?schema=public"
JWT_SECRET="super-secret-key-change-me-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-me"
JWT_REFRESH_EXPIRATION="7d"
AI_SERVICE_URL="http://localhost:8000"
REDIS_HOST=localhost
REDIS_PORT=6379

# Email Service (SMTP) - for verification & password reset
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=no-reply@yourdomain.com

# Webhook Security
WEBHOOK_SECRET="webhook-signature-secret-key"

# Feature Flags / LaunchDarkly
LAUNCHDARKLY_SDK_KEY=""
FEATURE_FLAG_EMAIL_VERIFICATION=true
FEATURE_FLAG_TWO_FACTOR=false

# ----------------------------
# AI Service (Python FastAPI)
# ----------------------------
GEMINI_API_KEY="your-google-gemini-api-key-here"
# Note: Local development uses AI_PORT. In production, platform sets PORT.
AI_PORT=8000
HOST="0.0.0.0"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:4000"

# ----------------------------
# Frontend (Next.js)
# ----------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_WIDGET_SCRIPT_URL="http://localhost:4000/widget/logicra-widget.js"
NEXT_PUBLIC_SENTRY_DSN=""
